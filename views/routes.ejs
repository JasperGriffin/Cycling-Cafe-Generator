<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <script defer type="text/javascript" src="routes.js"></script>

    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""/>

    <!-- Make sure you put this AFTER Leaflet's CSS -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin="">
    </script>

   <!-- Leaflet Fullscreen -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet.fullscreen@4.0.0/Control.FullScreen.css" />
    <script src="https://unpkg.com/leaflet.fullscreen@4.0.0/Control.FullScreen.js"></script>

    <link rel="stylesheet" type="text/css" href="routes.css">

    <%- include('templates/header.ejs') -%>
</head>
<body>

    <script>
        let data = '<%- JSON.stringify(data.message) %>'
        let cafesArr = `<%- JSON.stringify(data.cafes) %>`
        let cafeObj = JSON.parse(cafesArr)    
        let numOfCafes = Object.keys(cafeObj).length;
    </script>
    
    <div class="flex-container">
        
        <div id="map"></div>

        <div class="column-container">
            <div class="info-container">
            
                <h1><b><%= data.name %></b></h1>
                <br />
                <h2><b><%= data.distance %>km</b></h2>
                <br />
                <hr />
                <br />
                <% if(!data.error){ %>
                    <h3>Number of total cafes:        
                        <script>document.write(numOfCafes);</script>
                    </h3>
                    <br />
                <% } %> 
    
                <% if(data.error){ %>
                    <div class="error-message">
                        <b><%= data.error %></b>
                    </div>
                <% } %> 

            </div>

            <div class="return-button-container">
                <div class="return-button" id="return">
                    <a href="../">
                        <h3>Try another route</h3>
                    </a> 
                </div>

                <div class="return-button" id="contact">
                    <a href="../contact">
                        <h3>Cafe suggestions?</h3>
                    </a> 
                </div>
            </div>
            
        </div>
    </div>
    
    

</body> 

</html>   
<%- include('templates/footer.ejs') -%>
